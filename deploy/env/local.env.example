# BlueNote local dependency defaults.
# Values here are for local development only.

BLUENOTE_MYSQL_IMAGE=mysql:8.4
BLUENOTE_MYSQL_PORT=3306
BLUENOTE_MYSQL_ROOT_PASSWORD=bluenote_root_local

BLUENOTE_REDIS_IMAGE=redis:7.4-alpine
BLUENOTE_REDIS_PORT=6379
BLUENOTE_REDIS_PASSWORD=bluenote_redis_local

BLUENOTE_NACOS_IMAGE=nacos/nacos-server:v2.4.3
BLUENOTE_NACOS_PORT=8848
BLUENOTE_NACOS_GRPC_PORT=9848
BLUENOTE_NACOS_RAFT_PORT=9849

BLUENOTE_ROCKETMQ_IMAGE=apache/rocketmq:5.3.2
BLUENOTE_ROCKETMQ_NAMESRV_PORT=9876
BLUENOTE_ROCKETMQ_BROKER_PORT=10911
BLUENOTE_ROCKETMQ_BROKER_HA_PORT=10909

BLUENOTE_MINIO_IMAGE=quay.io/minio/minio:latest
BLUENOTE_MINIO_MC_IMAGE=quay.io/minio/mc:latest
BLUENOTE_MINIO_API_PORT=9000
BLUENOTE_MINIO_CONSOLE_PORT=9001
BLUENOTE_MINIO_ROOT_USER=bluenote_minio
BLUENOTE_MINIO_ROOT_PASSWORD=bluenote_minio_local
BLUENOTE_MINIO_BUCKET=bluenote-files
